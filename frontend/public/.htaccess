# ============================================================
# ChinguSpeak React Admin — root .htaccess
# Place this at:  public_html/.htaccess  on Hostinger
#
# What it does:
#   1. Real files / folders → serve as-is (CSS, JS, images, etc.)
#   2. /api/*  → never rewritten (handled by api/.htaccess inside the PHP folder)
#   3. /mobile/* → SPA fallback inside the Expo Web build
#   4. Anything else → /index.html so React Router can handle /login, /users, etc.
# ============================================================

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Real files / directories: serve as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2. /api/* → never rewrite (delegated to /api/.htaccess of the PHP backend)
  RewriteRule ^api(/.*)?$ - [L]

  # 3. /mobile/* (Expo Web build) → SPA fallback inside that subfolder
  RewriteRule ^mobile(/.*)?$ /mobile/index.html [L]

  # 4. Everything else → React Router (SPA fallback)
  RewriteRule ^ /index.html [L]
</IfModule>

# ============================================================
# Make sure the Authorization header (Bearer tokens) survives
# Apache/CGI by default strips this — without this, JWT login breaks.
# ============================================================
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP:Authorization} ^(.*)
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]
</IfModule>

# ============================================================
# Gzip / Deflate compression
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json application/xml image/svg+xml
</IfModule>

# ============================================================
# Browser caching for static assets
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"
  ExpiresByType text/html                     "access plus 0 seconds"
  ExpiresByType application/javascript        "access plus 1 year"
  ExpiresByType text/css                      "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType application/font-woff         "access plus 1 year"
  ExpiresByType application/font-woff2        "access plus 1 year"
</IfModule>

# ============================================================
# Security headers
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options             "nosniff"
  Header set Referrer-Policy                    "strict-origin-when-cross-origin"
  Header set X-Frame-Options                    "SAMEORIGIN"
  Header set Permissions-Policy                 "geolocation=(), microphone=(self), camera=(self)"
  # No-cache for index.html so users always get the latest React bundle pointer
  <FilesMatch "^(index\.html|service-worker\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# ============================================================
# Force HTTPS  (Hostinger gives a free Let's Encrypt SSL — turn this on AFTER SSL is active)
# ============================================================
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTPS} off
#   RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# ============================================================
# Block direct access to dot-files and source maps in production
# ============================================================
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
<FilesMatch "\.map$">
  Require all denied
</FilesMatch>
